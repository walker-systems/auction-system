########################################
# Monorepo root .gitignore
########################################

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDEs / Editors ---
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~

# --- Logs ---
*.log

# --- Java / Maven / Gradle ---
**/target/
**/dependency-reduced-pom.xml
**/.classpath
**/.project
**/.settings/
**/bin/
**/out/
hs_err_pid*
replay_pid*

# Keep Maven wrapper jar/properties if you use it (usually yes)
!**/.mvn/wrapper/maven-wrapper.properties
!**/.mvn/wrapper/maven-wrapper.jar
!**/mvnw
!**/mvnw.cmd

# --- Python ---
**/__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.venv/
venv/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# If PyCharm/IDE makes these:
sentinel-ml/.venv-notebook/
sentinel-ml/.venv-notebook/**

# --- Jupyter / notebooks outputs ---
**/.ipynb_checkpoints/

# --- ML artifacts / large generated files ---
# (Recommended: track the generation script + notebook, not the generated outputs)
*.cbm
*.csv
catboost_info/
catboost_info/**

# 👇 NEW: Explicitly allow the compiled model so Docker can boot!
!sentinel-ml/fraud_model.cbm

# --- Redis persistence artifacts ---
dump.rdb
*.rdb
appendonly.aof

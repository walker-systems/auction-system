#############################
# IDEs / Editors
#############################
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo

#############################
# OS junk
#############################
.DS_Store
Thumbs.db
Desktop.ini

#############################
# Java / Maven / Gradle build artifacts
#############################
**/target/
**/build/
**/.gradle/
**/dependency-reduced-pom.xml
**/*.log
hs_err_pid*
replay_pid*

# If you use Lombok delombok / annotation processors sometimes:
**/.apt_generated/
**/.classpath
**/.project
**/.settings/
**/bin/
**/out/

#############################
# Python environments / caches
#############################
**/__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.venv/
venv/
**/.python-version

# Your JetBrains-created notebook env folder
sentinel-ml/.venv-notebook/

#############################
# Jupyter / notebooks runtime junk
#############################
**/.ipynb_checkpoints/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

#############################
# Redis persistence artifacts
#############################
dump.rdb
*.rdb
appendonly.aof

#############################
# ML training artifacts (usually huge / machine-specific)
#############################
# CatBoost training outputs
**/catboost_info/
# If you create local datasets you don’t want tracked:
*.csv

#############################
# Python packaging outputs
#############################
**/*.egg-info/
**/dist/
**/.eggs/

#############################
# Local env / secrets
#############################
.env
.env.*
!.env.example
**/secrets/
**/*secret*
**/*apikey*
**/*api_key*
**/*token*

#############################
# Docker / compose runtime
#############################
**/.dockerignore
